DB_MODE=external

FRONTEND_IMAGE=ghcr.io/your-org/strategic-task-management:main
BACKEND_IMAGE=ghcr.io/your-org/sism-backend:main

DB_HOST=127.0.0.1
DB_PORT=5432
DB_URL=jdbc:postgresql://127.0.0.1:5432/sism_prod?stringtype=unspecified
DB_USERNAME=sism_prod_user
DB_PASSWORD=change_me

JWT_SECRET=change_me_to_a_long_random_secret
ALLOWED_ORIGINS=https://your-domain.example
SPRING_FLYWAY_ENABLED=true

BACKEND_PORT=8080
FRONTEND_PORT=80

JAVA_HEAP_SIZE=384m
JAVA_METASPACE_SIZE=128m
JAVA_STACK_SIZE=512k
DB_HIKARI_MAX_POOL_SIZE=2
DB_HIKARI_MIN_IDLE=1
