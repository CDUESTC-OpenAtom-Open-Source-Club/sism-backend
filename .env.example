# =============================================================================
# SISM Backend Environment Variables
# =============================================================================
# 复制此文件为 .env 并填写实际值
# Copy this file to .env and fill in the actual values
# =============================================================================

# -----------------------------------------------------------------------------
# 必需变量 (Required Variables)
# 这些变量必须配置，否则应用无法启动
# -----------------------------------------------------------------------------

# JWT 签名密钥 (JWT Signing Secret Key)
# 要求: 至少 256 位 (32 字符)，建议使用随机生成的字符串
# 生成方法: openssl rand -base64 32
# 参考: Requirements 1.1.1
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long-change-this

# 数据库连接 URL (Database Connection URL)
# 本地受信任开发环境可使用:
#   jdbc:postgresql://localhost:5432/database?stringtype=unspecified&sslmode=disable&connectTimeout=10&socketTimeout=30&tcpKeepAlive=true
# OpenTenBase / PostgreSQL 兼容实例也沿用该 JDBC 形态:
#   jdbc:postgresql://otb-host:5432/database?stringtype=unspecified&sslmode=disable&connectTimeout=10&socketTimeout=30&tcpKeepAlive=true
# 远程/生产数据库必须校验服务端身份，推荐使用:
#   jdbc:postgresql://db.example.com:5432/database?stringtype=unspecified&sslmode=verify-full&connectTimeout=10&socketTimeout=30&tcpKeepAlive=true
# stringtype=unspecified 允许 PostgreSQL 接受字符串值作为原生 ENUM 列
# 对远程数据库，不要依赖 loginTimeout 作为 SCRAM DoS 的完整缓解；应优先升级 pgjdbc，并使用 verify-full 与受信任 CA 校验服务端身份
# 参考: Requirements 1.1.2
DB_URL=jdbc:postgresql://localhost:5432/strategic?stringtype=unspecified&sslmode=disable&connectTimeout=10&socketTimeout=30&tcpKeepAlive=true

# 数据库用户名 (Database Username)
# 参考: Requirements 1.1.2
DB_USERNAME=postgres

# 数据库密码 (Database Password)
# 参考: Requirements 1.1.2
DB_PASSWORD=your_password_here

# Spring Profile 切换
# PostgreSQL 默认留空或不设置
# OpenTenBase 需设置为:
#   SPRING_PROFILES_ACTIVE=opentenbase
# 这样仍然只需要维护一个 .env 文件。
SPRING_PROFILES_ACTIVE=

# -----------------------------------------------------------------------------
# 可选变量 (Optional Variables)
# 这些变量有默认值，可根据需要覆盖
# -----------------------------------------------------------------------------

# Redis 启用开关
# 默认: false (开发环境不需要 Redis)
# 生产环境建议启用以提升性能
REDIS_ENABLED=false

# JWT Token 有效期 (毫秒)
# 默认: 86400000 (24小时) - 开发环境
# 默认: 28800000 (8小时) - 生产环境
# JWT_EXPIRATION=86400000

# JWT Refresh Token 有效期 (毫秒)
# 默认: 604800000 (7天)
# JWT_REFRESH_EXPIRATION=604800000

# 服务器端口
# 默认: 8080
# SERVER_PORT=8080

# 不要设置 SERVER_CONTEXT_PATH。
# 控制器已统一使用 /api/v1 前缀；如果这里再配置 /api 或 /api/v1，会导致路径重复。
# SERVER_CONTEXT_PATH=

# 日志路径 (生产环境)
# 默认: /var/log/sism
# LOG_PATH=/var/log/sism

# 日志级别配置
# LOG_LEVEL_ROOT=INFO
# LOG_LEVEL_APP=DEBUG
# LOG_LEVEL_SPRING=INFO
# LOG_LEVEL_SECURITY=INFO
# LOG_LEVEL_SQL=DEBUG
# LOG_LEVEL_SQL_BINDER=TRACE

# CORS 允许的源 (生产环境)
# 默认: https://blackevil.cn
# ALLOWED_ORIGINS=https://your-domain.com

# Swagger UI 开关 (生产环境默认关闭)
# SWAGGER_ENABLED=false

# 是否允许公开访问 Swagger / OpenAPI 文档
# 生产环境建议保持 false
# PUBLIC_DOCS_ENABLED=false

# 是否允许公开访问 Actuator 端点
# 生产环境建议保持 false
# PUBLIC_ACTUATOR_ENABLED=false

# Actuator 暴露端点（生产默认只保留 health）
# ACTUATOR_EXPOSED_ENDPOINTS=health

# Health 详细信息显示策略
# 可选: never / when_authorized / always
# ACTUATOR_HEALTH_SHOW_DETAILS=never

# -----------------------------------------------------------------------------
# 数据库连接池配置 (生产环境可选)
# -----------------------------------------------------------------------------

# 最大连接数
# 默认: 20
# DB_POOL_MAX_SIZE=20

# 最小空闲连接数
# 默认: 10
# DB_POOL_MIN_IDLE=10

# 连接超时时间 (毫秒)
# 默认: 30000
# DB_CONNECTION_TIMEOUT=30000

# 空闲超时时间 (毫秒)
# 默认: 600000
# DB_IDLE_TIMEOUT=600000

# 连接最大生命周期 (毫秒)
# 默认: 1800000
# DB_MAX_LIFETIME=1800000

# 连接泄漏检测阈值 (毫秒)
# 默认: 60000
# DB_LEAK_DETECTION=60000

# -----------------------------------------------------------------------------
# 安全扫描配置 (Security Scanning Configuration)
# -----------------------------------------------------------------------------

# NVD API Key for OWASP Dependency Check
# 获取方法: https://nvd.nist.gov/developers/request-an-api-key
# 强烈推荐: 没有 API Key 时，NVD 数据更新会非常慢且可能失败
# Highly recommended: Without an API key, NVD updates can be very slow and may fail
# NVD_API_KEY=your-nvd-api-key-here
